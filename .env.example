FOOD_OPTIMISATION_ENABLED="false"
BOOKING_CONVERSION_INGEST_SECRET="changeme-booking-conversion-secret"
BOOKING_CONVERSION_ACCOUNT_ID="00000000-0000-0000-0000-000000000000"

# Client/public envs
NEXT_PUBLIC_FACEBOOK_APP_ID="changeme-facebook-app-id"
NEXT_PUBLIC_SITE_URL="https://localhost:3000"
NEXT_PUBLIC_SUPABASE_ANON_KEY="changeme-supabase-anon"
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
# Feature flag: enable the food_booking paid campaign type (true/1 to enable; ships dark by default)
NEXT_PUBLIC_ENABLE_FOOD_BOOKING="false"
