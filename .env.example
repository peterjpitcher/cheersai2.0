# Server secrets
ALERTS_SECRET="changeme-alerts-secret"
CRON_SECRET="changeme-cron-secret"
INTERNAL_RENDER_SECRET=""
INTERNAL_RENDER_URL=""
FACEBOOK_APP_SECRET="changeme-fb-secret"
TOKEN_VAULT_KEY="generate-with-openssl-rand-hex-32"
TOKEN_VAULT_KEY_VERSION="1"
GOOGLE_MY_BUSINESS_CLIENT_ID="changeme-gbp-client-id"
GOOGLE_MY_BUSINESS_CLIENT_SECRET="changeme-gbp-client-secret"
INSTAGRAM_APP_ID="changeme-instagram-app-id"
INSTAGRAM_APP_SECRET="changeme-instagram-app-secret"
INSTAGRAM_VERIFY_TOKEN="changeme-instagram-verify-token"
OPENAI_API_KEY="sk-your-openai-key"
RESEND_API_KEY="re_your-resend-key"
