# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# supabase generated artifacts
supabase/.temp/
supabase/.branches/
supabase/remote-*-backup.sql
# staged v1 baseline (scripts/build-v1-baseline.py) — staged by CI and db:rebuild only,
# must never be committed or pushed to prod
supabase/migrations/20260519230001_v1_baseline.sql
/temp/
.worktrees/
.claude/worktrees/
.claire/
.claude/session-context.md
.claude/changes-manifest.log
.claude/docs/

# generated agent investigation artifacts
tasks/banner-*.md
tasks/codex-qa-review/*-review-pack.md
tasks/codex-qa-review/*-findings.json
.env*.local
node-compile-cache/

# graphify knowledge-graph output (generated tooling artifact)
graphify-out/
